    "mapbox-gl": "^3.26.0",
    "next": "^16.2.10",
    "node-cron": "^4.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.34.5",
    "three": "^0.177.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/node-cron": "^3.0.11",

# PostgreSQL + PostGIS (production / local Docker)
# Use a managed host (Neon, Supabase, RDS) with SSL:
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.xxxx.supabase.co:5432/postgres?sslmode=require"
#
# Or local PostGIS via docker compose:
DATABASE_URL="postgresql://ethiomls:ethiomls@localhost:5432/ethiomls?schema=public"

# Redis (BullMQ broadcast queue — see docker-compose.yml)
REDIS_URL="redis://127.0.0.1:6379"

# Public site URL used in SMS + Telegram deep links
NEXT_PUBLIC_SITE_URL="https://ethiomls.info"

# Optional National Bank of Ethiopia USD/ETB day-rate override (proxy used if unset)
# NBE_USD_ETB_RATE=128.75
# NEXT_PUBLIC_NBE_USD_ETB_RATE=128.75

# Local financial rails (mock webhook signature secrets)
# TELEBIRR_WEBHOOK_SECRET=telebirr-dev-secret
# CBE_BIRR_WEBHOOK_SECRET=cbe-birr-dev-secret

# SMS transport: mock | hahu | afromessage | smsethiopia
SMS_PROVIDER="mock"
SMS_FROM="EthioMLS"
# Hahu.io (https://hahu.io) — Android SMS gateway
# HAHU_API_SECRET=
# HAHU_DEVICE_ID=
# HAHU_SIM=1
# HAHU_PRIORITY=1
# HAHU_API_URL=https://hahu.io/api/send/sms
# AFROMESSAGE_API_KEY=
# AFROMESSAGE_IDENTIFIER_ID=EthioMLS
# SMSETHIOPIA_API_KEY=
# SMSETHIOPIA_API_URL=https://api.smsethiopia.et/v1/messages

# Telegram Bot API (omit token to mock-publish to console)
# TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL="@EthioMLS_Official"

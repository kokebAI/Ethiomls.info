# Supabase Postgres (pooler)
# DATABASE_URL — transaction pooler :6543 (?pgbouncer=true) for the app
# DIRECT_URL  — session pooler :5432 for migrations
# DATABASE_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres"
#
# Local PostGIS via docker compose (fallback):
# DATABASE_URL="postgresql://ethiomls:ethiomls@localhost:5432/ethiomls?schema=public"
# DIRECT_URL="postgresql://ethiomls:ethiomls@localhost:5432/ethiomls?schema=public"
DATABASE_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# Redis (BullMQ broadcast queue — see docker-compose.yml)
REDIS_URL="redis://127.0.0.1:6379"

# Public site URL used in SMS + Telegram deep links
NEXT_PUBLIC_SITE_URL="https://ethiomls.info"

# Gemini via @google/genai — required for document parse + search assist
# Set the same key in Vercel Project Settings → Environment Variables (Production).
# Prefer an AI Studio key (AIza…). AQ.* keys usually need GEMINI_VERTEXAI=true.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash-lite
# Optional Vertex (needs Agent Platform API enabled on the GCP project):
# GEMINI_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1
# Optional AI Gateway base URL (Netlify auto-injects when AI is enabled):
# GOOGLE_GEMINI_BASE_URL=

# Auth session signing (required in production)
# AUTH_SESSION_SECRET=replace-with-long-random-string

# Google / Gmail OAuth (leave unset until credentials exist)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Optional National Bank of Ethiopia USD/ETB day-rate override (proxy used if unset)
# Optional manual override — normally unnecessary: the app pulls the official
# NBE USD/ETB indicative rate live from api.nbe.gov.et (1-hour cache).
# NBE_USD_ETB_RATE=

# Local financial rails (mock webhook signature secrets)
# TELEBIRR_WEBHOOK_SECRET=telebirr-dev-secret
# CBE_BIRR_WEBHOOK_SECRET=cbe-birr-dev-secret

# SMS transport: mock | hahu | afromessage | smsethiopia
SMS_PROVIDER="mock"
SMS_FROM="EthioMLS"
# Hahu.io (https://hahu.io) — Android SMS gateway
# HAHU_API_SECRET=
# HAHU_DEVICE_ID=sm-g9700
# HAHU_SIM=1
# HAHU_PRIORITY=1
# HAHU_API_URL=https://hahu.io/api/send/sms
# AFROMESSAGE_API_KEY=
# AFROMESSAGE_IDENTIFIER_ID=EthioMLS
# SMSETHIOPIA_API_KEY=
# SMSETHIOPIA_API_URL=https://api.smsethiopia.et/v1/messages

# Telegram Bot API (omit token to mock-publish to console)
# TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL="@EthioMLS_Official"
